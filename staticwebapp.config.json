{
  "auth": {
    "identityProviders": {
      "azureActiveDirectory_B2C": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/ab4a18a3-81ca-46ef-9ff5-c48f63662f31/v2.0",
          "clientIdSettingName": "AZURE_EXT_CLIENT_ID",
          "clientSecretSettingName": "AZURE_EXT_CLIENT_SECRET"
        },
        "login": {
          "name": "aad-ext"
        }
      }
    }
  },
  "routes": [
    {
      "route": "/login",
      "statusCode": 302,
      "redirect": "/.auth/login/aad-ext"
    },
    {
      "route": "/logout",
      "statusCode": 302,
      "redirect": "/.auth/logout"
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/login"
    }
  }
}