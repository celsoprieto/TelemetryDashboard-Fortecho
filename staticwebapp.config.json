{
  "routes": [
    {
      "route": "/login",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/loggedout",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/api/FSIoTHubConnectionEvents",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": { "redirect": "/login" }
  },
  "auth": {
    "identityProviders": {
      "customOpenIdConnectProviders": {
        "externalid": {
          "registration": {
            "clientIdSettingName": "EXTERNALID_CLIENT_ID",
            "clientCredential": {
              "clientSecretSettingName": "EXTERNALID_CLIENT_SECRET"
            },
            "openIdConnectConfiguration": {
              "wellKnownOpenIdConfiguration": "https://celsoprietocustomers.ciamlogin.com/ab4a18a3-81ca-46ef-9ff5-c48f63662f31/v2.0/.well-known/openid-configuration"
            }
          },
          "login": {
            "nameClaimType": "name"
          }
        },
        "entra": {
          "registration": {
            "clientIdSettingName": "ENTRA_CLIENT_ID",
            "clientCredential": {
              "clientSecretSettingName": "ENTRA_CLIENT_SECRET"
            },
            "openIdConnectConfiguration": {
              "wellKnownOpenIdConfiguration": "https://login.microsoftonline.com/e180796e-63ef-436d-9169-ea6d797836da/v2.0/.well-known/openid-configuration"
            }
          },
          "login": {
            "nameClaimType": "name"
          }
        }
      }
    }
  }
}