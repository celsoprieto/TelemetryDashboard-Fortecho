{
  "auth": {
    "identityProviders": {
      "customOpenIdConnect": {
        "aad-ext": {
          "registration": {
            "clientIdSettingName": "AZURE_EXT_CLIENT_ID",
            "clientSecretSettingName": "AZURE_EXT_CLIENT_SECRET",
            "openIdConnectConfiguration": {
              "wellKnownOpenIdConfiguration": "https://login.microsoftonline.com/ab4a18a3-81ca-46ef-9ff5-c48f63662f31/v2.0/.well-known/openid-configuration"
            }
          }
        }
      }
    }
  },
  "routes": [
    {
      "route": "/login",
      "statusCode": 302,
      "redirect": "/.auth/login/customOpenIdConnect/aad-ext"
    },
    {
      "route": "/logout",
      "statusCode": 302,
      "redirect": "/.auth/logout"
    },
    {
      "route": "/",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/login"
    }
  }
}