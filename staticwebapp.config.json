{
  "routes": [
    {
      "route": "/login",
      "redirect": "/api/login",
      "statusCode": 302
    },
    {
      "route": "/callback",
      "redirect": "/api/callback",
      "statusCode": 302
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["anonymous", "authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/login"
    }
  }
}